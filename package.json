{
  "name": "seed-and-spoon-backend",
  "version": "1.0.0",
  "description": "Backend API for Seed & Spoon nonprofit - food bank directory, donations, and volunteer management",
  "private": true,
  "scripts": {
    "dev": "bun --bun next dev",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "lint": "bun --bun next lint",
    "seed": "bun --bun scripts/seed-database.js",
    "seed:all": "bun --bun scripts/seed-all-counties.js",
    "seed:newark-essex": "bun --bun scripts/seed-newark-essex.js",
    "seed:hudson": "bun --bun scripts/seed-hudson.js",
    "seed:union": "bun --bun scripts/seed-union.js",
    "seed:bergen": "bun --bun scripts/seed-bergen.js",
    "import:csv": "bun --bun scripts/import-csv.js",
    "preinstall": "node scripts/check-npm.js"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-slot": "^1.0.2",
    "@supabase/supabase-js": "^2.39.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.312.0",
    "next": "^14.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "stripe": "^14.10.0",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "dotenv": "^16.3.1",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.0.4",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": "20.x",
    "bun": ">=1.0.0"
  }
}
